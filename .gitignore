# Python
venv*/
__pycache__/
*.pyc
*.egg-info/

# Scraped-data files are committed so the benchmark is fully deterministic
# across reruns — scraper APIs can rate-limit, change responses, or expire
# issues between runs. To regenerate instead, see data/scrape_*.py.
# Previously gitignored: data/github_issues.json, data/bugzilla_bugs.json

# Results (regenerate with benchmark/ scripts)
results/raw/
results/figures/
results-*/

# Keep committed run data and aggregated results
!results/runs/
!results/aggregated/

# Vector store data
.chroma/
.chroma_bench/
*.db

# Docker volumes
ollama_data/
pg_data/
qdrant_data/

# Node (Playwright collection script)
node_modules/
package-lock.json

# Temp/generated data files (regenerated by pipeline)
data/bug_reports_v2.json
data/pairs_v2.csv

# System files
.DS_Store
.env
.setup
